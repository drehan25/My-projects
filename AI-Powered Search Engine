# AI-Powered Search Engine
# Reproduces the code behind this project

from exa_py import Exa

# Initialize the Exa client with your API key
exa = Exa('YOUR_API_KEY_HERE')

# Get search query from user
query = input('Search here: ')

# Get number of results from user
num_results = int(input('How many results would you like? '))

# Send search request to Exa API
response = exa.search_and_contents(
    query,
    num_results=num_results,
    type='neural',
    summary=True
)

# Display results
print(f'\nTop {num_results} results for: "{query}"\n')
print('=' * 50)

for i, result in enumerate(response.results, start=1):
    print(f'Result {i}:')
    print(f'Title:   {result.title}')
    print(f'URL:     {result.url}')
    
    if result.summary:
        print(f'Summary: {result.summary}')
    
    print('-' * 50)
